@model GestaPME.ViewModels.Conta.CadastroEmpresaViewModel
@{
    ViewData["Title"] = "Cadastrar empresa";
    Layout = "_LayoutPublic";
}
<h2 class="mb-1"><i class="bi bi-hexagon-fill text-primary"></i> GestaPME</h2>
<p class="text-muted mb-4">Cadastre sua empresa</p>

<form asp-action="Cadastro" method="post" novalidate>
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <h3 class="gp-label mb-2">Dados da empresa</h3>
    <div class="mb-3">
        <label asp-for="RazaoSocial" class="form-label"></label>
        <input asp-for="RazaoSocial" class="form-control"/>
        <span asp-validation-for="RazaoSocial" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NomeFantasia" class="form-label"></label>
        <input asp-for="NomeFantasia" class="form-control"/>
        <span asp-validation-for="NomeFantasia" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="Cnpj" class="form-label"></label>
        <input asp-for="Cnpj" class="form-control" placeholder="00.000.000/0000-00"/>
        <div class="gp-field-hint">Apenas números ou formato 00.000.000/0000-00</div>
        <span asp-validation-for="Cnpj" class="text-danger small"></span>
    </div>

    <h3 class="gp-label mb-2">Dados do administrador</h3>
    <div class="mb-3">
        <label asp-for="NomeAdmin" class="form-label"></label>
        <input asp-for="NomeAdmin" class="form-control"/>
        <span asp-validation-for="NomeAdmin" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="EmailAdmin" class="form-label"></label>
        <input asp-for="EmailAdmin" class="form-control"/>
        <span asp-validation-for="EmailAdmin" class="text-danger small"></span>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Senha" class="form-label"></label>
            <input asp-for="Senha" type="password" class="form-control"/>
            <div class="gp-field-hint">Mínimo 8 caracteres, com letras e números</div>
            <span asp-validation-for="Senha" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="ConfirmarSenha" class="form-label"></label>
            <input asp-for="ConfirmarSenha" type="password" class="form-control"/>
            <span asp-validation-for="ConfirmarSenha" class="text-danger small"></span>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <a asp-action="Login" class="btn btn-link">Cancelar</a>
        <button type="submit" class="btn btn-primary">Criar conta</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/> 
}
