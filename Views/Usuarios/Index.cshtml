@model List<GestaPME.Models.Usuario>
@{ ViewData["Title"] = "Usuários"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Usuários</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus"></i> Novo usuário</a>
</div>
<table class="gp-table">
    <thead>
    <tr>
        <th>Nome</th>
        <th>E-mail</th>
        <th>Perfil</th>
        <th>Status</th>
        <th style="width:180px">Ações</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var u in Model){
        <tr>
            <td>@u.Nome</td>
            <td>@u.Email</td>
            <td>@u.Perfil</td>
            <td>
                @if (u.Ativo){
                    <span class="gp-badge gp-badge-success">Ativo</span>
                }
                else{
                    <span class="gp-badge gp-badge-danger">Inativo</span>
                }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@u.Id" class="text-muted me-2" title="Editar"><i
                        class="bi bi-pencil"></i></a>
                <a asp-action="ResetarSenha" asp-route-id="@u.Id" class="text-muted me-2" title="Redefinir senha"><i
                        class="bi bi-key"></i></a>
                <form asp-action="AlternarAtivo" asp-route-id="@u.Id" method="post" class="d-inline"
                      onsubmit="return confirm('Alternar o status de @u.Nome?');">
                    <button type="submit" class="btn btn-link p-0 text-muted" title="Ativar/Inativar">
                        <i class="bi bi-@(u.Ativo ? "toggle-on" : "toggle-off")"></i>
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
