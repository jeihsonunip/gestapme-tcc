{
  "version": "1.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "bootstrap@5.3.3",
      "destination": "wwwroot/lib/bootstrap/",
      "files": [ "js/bootstrap.bundle.min.js", "css/bootstrap.min.css" ]
    },
    {
      "library": "bootstrap-icons@1.11.3",
      "destination": "wwwroot/lib/bootstrap-icons/",
      "files": [ "font/bootstrap-icons.css", "font/fonts/bootstrap-icons.woff", "font/fonts/bootstrap-icons.woff2" ]
    },
    {
      "library": "jquery@3.7.1",
      "destination": "wwwroot/lib/jquery/",
      "files": [ "jquery.min.js" ]
    },
    {
      "library": "jquery-validate@1.20.0",
      "destination": "wwwroot/lib/jquery-validate/",
      "files": [ "jquery.validate.min.js" ]
    },
    {
      "library": "jquery-validation-unobtrusive@4.0.0",
      "destination": "wwwroot/lib/jquery-validation-unobtrusive/",
      "files": [ "jquery.validate.unobtrusive.min.js" ]
    }
  ]
}
